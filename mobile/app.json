{
  "expo": {
    "name": "karekontrol-mobile",
    "slug": "karekontrol-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "karekontrol",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "apiTimeout": 30000,
      "enableDevtools": false,
      "router": {},
      "eas": {
        "projectId": "ebb477f8-9c19-4285-bece-8660497ef05f"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karekontrol.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "Prosedür adımları ve uyumsuzluk raporları için fotoğraf çekmek amacıyla kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Prosedür ve uyumsuzluk raporlarına görsel eklemek için galeri erişimi gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.karekontrol.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera izni gerekiyor.",
          "microphonePermission": "Mikrofon izni gerekiyor.",
          "recordAudioAndroid": false
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "karekontrol",
          "project": "karekontrol-mobile"
        }
      ],
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/ebb477f8-9c19-4285-bece-8660497ef05f"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "koraykunal"
  }
}
